# Copy to ../creds/api.env (gitignored) for local dev, or inject via
# Cloud Run env / Secret Manager in production.

# Port Cloud Run will set automatically in prod; 8080 is the default it expects.
PORT=8080

# Postgres connection string.
# Local docker-compose: postgres://vallejo:vallejo@localhost:5432/vallejo
# Cloud SQL (via connector): postgres://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# CORS: comma-separated allowed origins, or * for any.
CORS_ORIGINS=*

# Shared secret protecting the admin comment listing (GET /api/comments) and
# the /admin.html page. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Leave blank to keep the listing endpoint disabled.
ADMIN_TOKEN=

# Resend transactional email. Key from https://resend.com/api-keys (kept in
# ../creds/api.env, gitignored). RESEND_FROM must be an address on a domain you
# have verified in Resend (DKIM/SPF records added). Leave RESEND_API_KEY blank
# to disable email sending.
RESEND_API_KEY=
RESEND_FROM=donotreply@protectparking.com
# Staff inbox that receives a notification on each new comment.
RESEND_NOTIFY_TO=it@morrisdev.com
# Public base URL used to build the admin link in notification emails.
SITE_URL=https://protectparking.com

NODE_ENV=development
